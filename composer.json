{
    "name": "ssl-domain-tracker/app",
    "description": "SSL & Domain Expiry Tracking Application",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "SSL Domain Tracker Team",
            "email": "atc.domain.track@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.0",
        "ext-openssl": "*",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-json": "*",
        "ext-curl": "*",
        "phpmailer/phpmailer": "^6.8",
        "monolog/monolog": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "fakerphp/faker": "^1.21",
        "mockery/mockery": "^1.5",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "App\\Models\\": "src/Models/",
            "App\\Services\\": "src/Services/",
            "App\\Controllers\\": "src/Controllers/",
            "App\\Utils\\": "src/Utils/"
        },
        "files": [
            "config/config.php",
            "database/Database.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "phpstan": "phpstan analyse src tests --level=8",
        "phpcs": "phpcs src tests --standard=PSR12",
        "phpcbf": "phpcbf src tests --standard=PSR12",
        "install-db": "mysql -u root -p < database/schema.sql",
        "setup": [
            "@composer install",
            "mkdir -p logs ssl cron",
            "chmod 755 logs ssl cron"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}